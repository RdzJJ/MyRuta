{
  "name": "myruta-backend",
  "version": "1.0.0",
  "description": "MyRuta - Backend API with Express, Socket.io, and Prisma",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "build": "echo 'No build step needed for Node.js'",
    "test": "jest --detectOpenHandles",
    "test:watch": "jest --watch",
    "migrate": "prisma migrate dev",
    "migrate:prod": "prisma migrate deploy",
    "prisma:gen": "prisma generate",
    "prisma:studio": "prisma studio",
    "seed": "node prisma/seed.js",
    "db:seed": "prisma db seed",
    "lint": "eslint src --fix"
  },
  "keywords": [
    "myruta",
    "transport",
    "monitoring",
    "express",
    "socket.io",
    "prisma"
  ],
  "author": "MyRuta Team",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.1.1",
    "axios": "^1.5.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "redis": "^4.6.7",
    "socket.io": "^4.6.1"
  },
  "devDependencies": {
    "eslint": "^8.50.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "prisma": "^5.1.1",
    "supertest": "^6.3.3"
  }
}
