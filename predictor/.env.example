# MyRuta Predictor - Environment Variables
# Copy this file to .env and fill in the values

# Server Configuration
PORT=8001
ENV=development
DEBUG=True

# Backend Communication
BACKEND_URL=http://localhost:3000
BACKEND_API_KEY=your_api_key_here

# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/myruta_db
REDIS_URL=redis://localhost:6379

# Machine Learning
ML_MODEL_PATH=./models/delay_predictor_model.pkl
ML_SCALER_PATH=./models/scaler.pkl

# Authentication
JWT_SECRET=your_jwt_secret_here
JWT_ALGORITHM=HS256

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/predictor.log

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Prediction Model
MODEL_CONFIDENCE_THRESHOLD=0.7
MAX_PREDICTION_DELAY_MINUTES=120
